{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "description": "Express-based API service for the Builder Agent Chain platform",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build --workspace ai-engine && nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "prebuild": "npm run build --workspace ai-engine",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings=0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
