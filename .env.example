# ===========================================
# Builder Agent Chain - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Server ---
PORT=3001
# Origins allowed for CORS (comma-separated). Leave empty to allow all.
# Example: CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=

# --- LLM API ---
# ZAI/GLM API key (required for idea generation)
ZAI_API_KEY=
# Custom LLM API base URL (optional, defaults to the provider's default)
LLM_BASE_URL=
# LLM model name (optional, defaults to the provider's default)
LLM_MODEL=
# Max tokens for LLM responses (optional)
LLM_MAX_TOKENS=

# --- Public Mode ---
# Set to "true" to enable read-only public mode.
# Visitors can only view cached data; no API calls are made.
PUBLIC_READONLY_MODE=false
# Secret token for admin operations (refresh, generate).
# Required to access write endpoints in public mode.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=

# --- Idea Cache ---
# Path to persistent cache file. Set to enable cache persistence across restarts.
# Example: IDEA_CACHE_FILE=/var/lib/builder-agent-chain/idea-cache.json
IDEA_CACHE_FILE=
# Cache TTL in hours (default: 12h in dev, 24h in public-readonly mode)
IDEA_CACHE_TTL_HOURS=
# Generate ideas on server start (default: true)
IDEA_WARMUP_ON_START=true
# Background refresh interval in hours (default: 12)
IDEA_BACKGROUND_REFRESH_HOURS=
# Number of ideas per generation batch (default: 5)
IDEA_GENERATION_BATCH_SIZE=
# Maximum stored candidates (default: 60)
IDEA_MAX_STORED_CANDIDATES=
# Maximum source usage history records (default: 240)
IDEA_SOURCE_HISTORY_LIMIT=

# --- MCP (optional) ---
# Path to the RSS scout MCP server binary (optional)
MCP_RSS_SCOUT_PATH=

# --- Email Alerts (optional) ---
# Configure SMTP to receive alerts (e.g., when RSS sources fail).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ADMIN_ALERT_EMAIL_FROM=
ADMIN_ALERT_EMAIL_TO=
# Minimum minutes between duplicate alerts (default: 60)
ADMIN_ALERT_COOLDOWN_MINUTES=

# --- Frontend (set at build time) ---
# Base URL for the backend API. Leave empty for same-origin deployment.
# Example: VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=
