{
  "name": "ai-engine",
  "private": true,
  "version": "0.1.0",
  "description": "AI Engine for Builder Agent Chain - TypeScript agent orchestration with ZAI GLM-5 API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-prompts.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "fast-xml-parser": "^5.8.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
