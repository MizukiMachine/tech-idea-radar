# ZAI GLM API Key (required)
ZAI_API_KEY=your-api-key-here

# Model to use (optional, defaults to glm-5-turbo)
LLM_MODEL=glm-5-turbo

# Base URL (optional, defaults to ZAI GLM API)
LLM_BASE_URL=https://api.z.ai/api/anthropic

# Max tokens for responses (optional, defaults to 8192)
LLM_MAX_TOKENS=8192

# RSS sources. Leave empty to use built-in technology feeds.
# Example: RSS_FEEDS=[{"name":"Hacker News","url":"https://hnrss.org/frontpage"}]
RSS_FEEDS=
RSS_MAX_RELATED_ARTICLES=18
RSS_SOURCE_TOTAL_LIMIT=5
RSS_FETCH_TIMEOUT_MS=8000

# X API Bearer Token (optional, used for X trend enrichment)
X_BEARER_TOKEN=your-x-bearer-token-here

# Keep false to avoid extra User Read charges. Set true only when author names/handles are needed.
X_INCLUDE_USER_FIELDS=false

# X search cache TTL. Larger values reduce repeated X API reads during development.
X_API_CACHE_TTL_HOURS=6

# Optional persistent X search cache file. Leave empty for in-memory cache only.
X_API_CACHE_FILE=

# Development-only search fixture mode:
# off = live/cache behavior, record = save live search results, replay = never call X API,
# record-if-missing = reuse saved results and call X API only for missing queries.
X_SEARCH_FIXTURE_MODE=off

# Local fixture file for X_SEARCH_FIXTURE_MODE. Keep this under .tmp/ so it is not committed.
X_SEARCH_FIXTURE_FILE=.tmp/x-search-fixture.json
