{
  "name": "builder-agent-chain",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo workspace for the Builder Agent Chain project",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "ai-engine"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run backend:build && npm run frontend:build",
    "format": "prettier --write .",
    "backend:dev": "npm run dev --workspace backend",
    "backend:dev:3010": "PORT=3010 npm run dev --workspace backend",
    "backend:build": "npm run build --workspace backend",
    "backend:test": "npm run test --workspace backend",
    "backend:lint": "npm run lint --workspace backend",
    "frontend:dev": "npm run dev --workspace frontend",
    "frontend:dev:5180": "VITE_PROXY_TARGET=http://127.0.0.1:3010 npm run dev --workspace frontend -- --host 127.0.0.1 --port 5180",
    "frontend:build": "npm run build --workspace frontend",
    "frontend:preview": "npm run preview --workspace frontend",
    "frontend:test": "npm run test --workspace frontend",
    "frontend:lint": "npm run lint --workspace frontend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@types/cors": "^2.8.19",
    "eslint": "^9.4.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "prettier": "^3.2.5",
    "typescript-eslint": "^7.17.0"
  },
  "dependencies": {
    "cors": "^2.8.6"
  }
}
